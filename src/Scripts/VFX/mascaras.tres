code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_disabled, diffuse_lambert, specular_schlick_ggx;

uniform vec4 Color : source_color;
uniform sampler2D Text;
uniform vec4 ColorFresnel : source_color;



void fragment() {
// ColorParameter:3
	vec4 n_out3p0 = Color;


	vec4 n_out4p0;
// Texture2D:4
	n_out4p0 = texture(Text, UV);


// VectorOp:5
	vec4 n_out5p0 = n_out3p0 * n_out4p0;
	float n_out5p4 = n_out5p0.a;


// Fresnel:6
	float n_in6p3 = 2.00000;
	float n_out6p0 = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_in6p3);


// ColorParameter:7
	vec4 n_out7p0 = ColorFresnel;


// VectorOp:8
	vec4 n_out8p0 = vec4(n_out6p0) * n_out7p0;


// VectorOp:9
	vec4 n_out9p0 = n_out5p0 + n_out8p0;


// Output:0
	ALPHA = n_out5p4;
	EMISSION = vec3(n_out9p0.xyz);


}
"
